rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ══════════════════════════════════════════════════════════
    // YOLTIC — Storage Security Rules
    // Audio files isolated per user for linguistic auditing
    // ══════════════════════════════════════════════════════════

    // ─── Audio Files ─────────────────────────────────────────
    // Path: audio/{userId}/{conversationId}.wav
    // Only the authenticated user can upload to their own folder.
    // Max file size: 10MB
    // Only WAV audio content type allowed.

    match /audio/{userId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');

      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Catch-all: Deny everything else ─────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
